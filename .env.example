# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# Restart `npm run dev` after editing.

# --- Supabase (task board) -------------------------------------------------
# Supabase dashboard → Project Settings → API.
# Only the anon (public) key belongs here — never the service_role key.
# These are VITE_-prefixed so they reach the browser client.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Vista Social (Social Media tab) ---------------------------------------
# Vista Social → Settings → Account Settings → Integrations.
# Read server-side by the Vite dev proxy (vite.config.js); never sent to the
# browser. NOT VITE_-prefixed on purpose so it stays out of the client bundle.
VISTA_SOCIAL_API_KEY=

# --- Anthropic (AI generation: ad copy, captions, SEO draft generation) -----
# console.anthropic.com → API keys. Server-side only (dev proxy + api/claude.js +
# the SEO/GEO generation core); NOT VITE_-prefixed. Also set in Vercel for prod.
ANTHROPIC_API_KEY=

# --- Supabase service role (server-side jobs) -------------------------------
# Needed for SEO/GEO native generation (Phase 2): background jobs write to the DB
# without a user session, so they bypass RLS with the service-role key. Supabase
# dashboard → Project Settings → API → service_role. Server-side ONLY — NEVER
# VITE_-prefixed (it must never reach the browser). Also set in Vercel for prod.
SUPABASE_SERVICE_ROLE_KEY=

# --- GoHighLevel (CRM pipeline sync) -----------------------------------------
# Private Integration token (GHL → Settings → Private Integrations). Server-side
# only (dev proxy + api/ghl.js). Per-client location ids are set in-app on the
# CRM page. If you only have a legacy v1 location key, also set GHL_AUTH_MODE=v1.
GHL_API_KEY=
# GHL_AUTH_MODE=v1

# --- OpenAI (SEO/GEO AI Images) ----------------------------------------------
# console.openai.com → API keys. Image generation (gpt-image-1). Server-side
# only (api/seo-image.js + dev middleware); NOT VITE_-prefixed. Set in Vercel too.
OPENAI_API_KEY=

# --- KIE (SEO/GEO draft video generation) ------------------------------------
# Server-side only; NOT VITE_-prefixed. Set in Vercel for production.
KIE_API_KEY=

# --- Content Agent import (LOCAL migration tool ONLY) ------------------------
# NOT used by the app or any deployment — the SEO/GEO workspace runs entirely on
# THIS project's Supabase. These are only read by scripts/import-content-agent.mjs
# to back-fill data from the old Content Agent project. Leave blank unless you're
# running that one-off import locally. Do NOT set these in Vercel.
CONTENT_AGENT_SUPABASE_URL=
CONTENT_AGENT_SERVICE_ROLE_KEY=

# --- Main website publishing (DisruptorsMedia blog -> live site) -------------
# The public marketing site (disruptorsmedia.com) is a SEPARATE Supabase project.
# "Publish to main website" upserts an approved DisruptorsMedia draft into its
# public.posts table (is_published=true => live immediately). SERVICE-ROLE key:
# server-side ONLY (dev proxy in vite.config.js + api/publish-to-main-site.js);
# NEVER VITE_-prefixed (must not reach the browser). Set both in Vercel for prod.
# Scoped to the 'disruptors-media' client only (override via MAIN_SITE_CLIENT_ID).
MAIN_SITE_SUPABASE_URL=https://ulfnzcniivkjtfaoxfmi.supabase.co
MAIN_SITE_SUPABASE_SERVICE_ROLE_KEY=
# Optional overrides (defaults shown):
# MAIN_SITE_CLIENT_ID=disruptors-media
# MAIN_SITE_PUBLIC_URL=https://disruptorsmedia.com
# Hero image: generated with OpenAI (reuses OPENAI_API_KEY above) and uploaded to
# the main site's public Supabase Storage bucket. Set MAIN_SITE_GENERATE_IMAGE=0
# to publish without auto-generating a hero image.
# MAIN_SITE_IMAGE_BUCKET=blog-images
# MAIN_SITE_GENERATE_IMAGE=1
