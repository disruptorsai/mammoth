{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/vista-mcp", "destination": "/api/vista-mcp" },
    { "source": "/claude-api", "destination": "/api/claude" },
    { "source": "/ghl-api/:path*", "destination": "/api/ghl?path=:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
